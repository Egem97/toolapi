# App
APP_NAME=TOOL_API
APP_ENV=development
DEBUG=true
TIMEZONE=America/Lima

# API
API_V1_PREFIX=/v1
CORS_ORIGINS=["http://localhost:3000"]

# Seguridad / JWT
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=__GENERATE_WITH_openssl_rand_-hex_32__
JWT_ALGORITHM=HS256
# Validez del token estático en días (default 365)
JWT_ACCESS_TOKEN_EXPIRE_DAYS=365

# Identificador del sistema (se usa como 'sub' en el JWT)
SYSTEM_CLIENT_ID=tool-api-client

# Base de datos
POSTGRES_USER=__SET_ME__
POSTGRES_PASSWORD=__SET_ME__
POSTGRES_DB=__SET_ME__
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tool_api

# Redis
REDIS_URL=redis://localhost:6379/0

# Microsoft Graph (Client Credentials - app-only)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_GRAPH_SCOPE=https://graph.microsoft.com/.default

# Kissflow (acceso por Access Key)
KISSFLOW_SUBDOMAIN=alzaperu
KISSFLOW_ACCOUNT_ID=
KISSFLOW_ACCESS_KEY_ID=
KISSFLOW_ACCESS_KEY_SECRET=

# Rate limit
RATE_LIMIT_DEFAULT=60/minute
